# Environment Variables Example File
# Copy this file to .env and modify as needed
#
# --- Run matrix (short) ---
# | Mode              | Command / entry        | Mock (default)     | Local API (Flask)                          |
# |-------------------|------------------------|--------------------|--------------------------------------------|
# | Tauri desktop     | npm run tauri:dev      | .env VITE_USE_MOCK | Sidecar / start_python_server; get_flask |
# | Vite only         | npm run dev            | often true in DEV  | Set VITE_USE_MOCK=false + run Flask; CORS |
# | Vitest            | npm test               | mocks per test     | N/A                                        |
# Browser+Vite needs CORS_ALLOW origins including Vite origin when probing /api/health from discoverFlaskPortBrowser.

# Flask API (Python server): when set, `/api/*` requires Authorization: Bearer <token>
# Tauri should run with the same FLASK_API_TOKEN in its environment; Vite uses VITE_FLASK_API_TOKEN for browser requests.
FLASK_API_TOKEN=
VITE_FLASK_API_TOKEN=

# Optional: URL opened from the desktop title bar "Releases" control (manual updates; no auto-check).
# VITE_RELEASES_PAGE_URL=https://example.com/your-project/releases

# CORS (Flask): comma-separated origins; leave empty in production to disable cross-origin.
# CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOW_HEADERS=Content-Type,Authorization

# Browser / Vite (no Tauri): optional Flask discovery for /api/health probe when apiUrl is empty
# VITE_FLASK_PROBE_HOST=127.0.0.1
# VITE_FLASK_PROBE_PORT_MIN=5000
# VITE_FLASK_PROBE_PORT_MAX=5100

# Python server: use LangChain for Ollama/DeepSeek chat (invoke + stream). Set to false for legacy HTTP path.
# In pytest (FLASK_ENV=testing) the default is false unless you set USE_LANGCHAIN=true.
USE_LANGCHAIN=

# Mock Mode
# Enable mock mode for development (use mock data instead of real API)
# Values: 'true' | 'false'
# Default: auto-enabled in development mode if not explicitly set to 'false'
VITE_USE_MOCK=
