{
  "name": "ooc-app",
  "version": "0.2.0",
  "description": "OOC app use Tauri and Flask",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && node scripts/move-build-output.js",
    "build:python": "node scripts/python-runner.mjs server/build.py --current-platform-only",
    "server:dev": "node scripts/python-runner.mjs server/run.py",
    "server:dev:local": "node scripts/server-dev-local.mjs",
    "server:build": "node scripts/python-runner.mjs server/build.py --current-platform-only",
    "dev:web:local": "node scripts/web-dev-local.mjs",
    "dist": "npm run build && npm run tauri:build",
    "type-check": "tsc --noEmit",
    "lint": "npm run lint:ts && npm run lint:eslint && npm run lint:python && npm run lint:i18n",
    "lint:ts": "tsc --noEmit",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"playwright.config.ts\" \"playwright.flask.config.ts\" \"playwright.tauri.config.ts\"",
    "lint:python": "node scripts/python-runner.mjs -m flake8 server/src --config=server/.flake8",
    "lint:i18n": "node scripts/check-i18n-keys.mjs",
    "check": "npm run lint && npm run test:python",
    "check:desktop-ga": "node scripts/desktop-ga-check.mjs",
    "env:dev": "cp .env.development .env",
    "env:prod": "cp .env.production .env",
    "env:example": "cp .env.example .env",
    "setup:dev": "npm run env:dev && npm install",
    "setup:prod": "npm run env:prod && npm install",
    "test": "node scripts/run-frontend-tests.mjs",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage:watch": "vitest --coverage",
    "test:python": "node scripts/python-runner.mjs -m pytest server",
    "test:python:coverage": "node scripts/python-runner.mjs -m pytest --cov=server/src --cov-report=html server",
    "test:e2e": "playwright test",
    "test:e2e:flask": "playwright test --config=playwright.flask.config.ts",
    "test:e2e:tauri": "playwright test --config=playwright.tauri.config.ts",
    "test:e2e:install": "playwright install"
  },
  "keywords": [
    "Tauri",
    "React",
    "Python"
  ],
  "author": "Patrick Zhang",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "overrides": {
    "esbuild": "^0.25.11",
    "rollup": "^4.59.0",
    "vitest": {
      "vite": "^6.4.2"
    },
    "vite-node": {
      "vite": "^6.4.2"
    }
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.10.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.49.1",
    "@srsholmes/tauri-playwright": "^0.2.2",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/css-modules": "^1.0.5",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/react-redux": "^7.1.34",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "sass": "^1.101.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^8.0.16",
    "vitest": "^2.1.9"
  }
}
