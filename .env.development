# Development Environment Configuration

# Optional: enable Flask Bearer auth locally (must match VITE_FLASK_API_TOKEN if both set).
# FLASK_API_TOKEN=
# VITE_FLASK_API_TOKEN=

# Mock Mode
# Enable mock mode for development (use mock data instead of real API)
# Values: 'true' | 'false'
# Default: auto-enabled in development mode if not explicitly set to 'false'
VITE_USE_MOCK=true
